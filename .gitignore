(# .gitignore for JavaScript / TypeScript projects using Playwright
# Includes Node modules, build output, Playwright test artifacts, IDE files (VS Code / JetBrains),
# OS files, env files and other temporary files that should not be committed to git.

# Node
node_modules/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Dependency directories
/.pnp
.pnp.js

# Build output
/dist/
/build/
/out/
/lib/
/es/
/target/
/.next/
/.nuxt/
/.vercel/

# Coverage reports
/coverage/
/.nyc_output/
coverage-final.json

# TypeScript
*.tsbuildinfo
tsconfig.tsbuildinfo

# Playwright test artifacts
test-results/
playwright-report/
.playwright/
traces/
trace.zip
*.trace
videos/
screenshots/
artifacts/
playwright-report-*/

# Test results / reporters (Jest / Mocha / others)
jest-result.json

# Environment files
.env
.env.local
.env.*.local
.env.test
.env.production.local

# VS Code
.vscode/

# JetBrains / IntelliJ IDEA
.idea/
*.iml
workspace.xml
usage.statistics.xml
tasks.xml

# Editor temporary files
*~
*.swp
*.swo
*.tmp
*.bak

# OS generated files
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
Icon

# Package managers
.cache/
.npm/
.pnpm-store/
.pnpm-debug.log

# Yarn (preserve selective .yarn entries if you track them intentionally)
.yarn/*
!.yarn/releases
!.yarn/plugins
!.yarn/sdks
!.yarn/patches

# Misc
*.orig
*.rej
*.patch
*.sublime-workspace

# Docker
docker-compose.override.yml
docker-compose.*.yml

# Build artifacts from various tools
/.cache/

# ESLint cache
.eslintcache

# Storybook
.out/

# Optional: lockfiles are usually committed; do NOT ignore package-lock.json / yarn.lock by default
# If you want to ignore specific lockfiles, add them here.

